{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.lazyants/transkribus",
  "description": "MCP server for the Transkribus REST API — collections, documents, HTR/OCR, and models.",
  "repository": {
    "url": "https://github.com/lazyants/transkribus-mcp-server",
    "source": "github"
  },
  "version": "1.0.0",
  "icon": {
    "src": "https://raw.githubusercontent.com/lazyants/transkribus-mcp-server/main/logo.png",
    "mimeType": "image/png",
    "sizes": ["400x400"]
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@lazyants/transkribus-mcp-server",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      }
    }
  ]
}
